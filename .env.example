# LLM provider keys (set at least one)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Database (defaults to SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./proxy.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://proxy:proxy@localhost:5432/llm_proxy

# Security — change before deploying
PROXY_MASTER_KEY=change-me-in-production

# ChromaDB persistent directory
CHROMA_PERSIST_DIR=./chroma_data

# Optional Redis for rate limiting across multiple workers
# RATE_LIMIT_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0

# LLM caching (exact-match; same messages → cached response, no upstream call)
# CACHE__ENABLED=true
# CACHE__TYPE=local          # "local" (per-process) or "redis" (shared across workers)
# CACHE__TTL=3600
# CACHE__REDIS_HOST=localhost
# CACHE__REDIS_PORT=6379

# LLM fallbacks (tried in order if primary model fails or hits context-window limit)
# LLM__FALLBACK_MODELS=["claude-3-5-sonnet-20241022","gpt-4o-mini"]

# Langfuse analytics (optional)
# ANALYTICS__ENABLED=true
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000   # omit to use Langfuse Cloud
# LANGFUSE_NEXTAUTH_SECRET=...          # only needed for self-hosted docker setup
# LANGFUSE_SALT=...                     # only needed for self-hosted docker setup
